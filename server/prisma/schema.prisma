generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum WorkoutType {
  TRAIL_RUN
  ROAD_RUN
  HIKE
  CYCLING
  STRENGTH
  OTHER
}

enum FileFormat {
  FIT
  GPX
  TCX
  STRAVA
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  displayName  String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  emailVerified            Boolean   @default(true)
  emailVerificationToken   String?   @unique
  emailVerificationExpiry  DateTime?
  passwordResetToken       String?   @unique
  passwordResetExpiry      DateTime?
  tokenVersion             Int       @default(0)

  stravaAthleteId    String?   @unique
  stravaAccessToken  String?
  stravaRefreshToken String?
  stravaTokenExpiry  DateTime?

  adventureModeEnabled        Boolean  @default(false)
  adventureCharacterArchetype String?  // "wizard" | "archer" | "warrior"
  adventureCharacterGender    String?  // "male" | "female"
  adventureCharacterColor     String?  // "blue" | "green" | "red" | "yellow"
  adventureDifficulty         String   @default("medium") // "easy" | "medium" | "hard" | "epic"
  adventureStartedAt          DateTime? // when adventure mode was first enabled
  adventureTotalXp            Int      @default(0) // cumulative XP earned since adventureStartedAt

  workouts Workout[]
  quests   Quest[]

  @@map("users")
}

model Workout {
  id               String      @id @default(cuid())
  userId           String
  user             User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  title            String
  workoutType      WorkoutType @default(TRAIL_RUN)
  fileFormat       FileFormat
  originalFileName String
  startTime        DateTime
  endTime          DateTime
  elapsedSeconds   Int

  // Distance & Pace
  distanceMiles      Float
  avgPaceSecPerMile  Float
  bestPaceSecPerMile Float?

  // Elevation (feet)
  elevationGainFt Float
  elevationLossFt Float
  avgElevationFt  Float
  maxElevationFt  Float?
  minElevationFt  Float?

  // Heart Rate (BPM)
  avgHeartRate Int?
  maxHeartRate Int?
  minHeartRate Int?

  calories Int?
  notes    String?

  stravaActivityId String? @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  splits      Split[]
  trackPoints TrackPoint[]

  @@index([userId, startTime(sort: Desc)])
  @@index([userId, workoutType])
  @@map("workouts")
}

model Split {
  id        String  @id @default(cuid())
  workoutId String
  workout   Workout @relation(fields: [workoutId], references: [id], onDelete: Cascade)

  splitNumber     Int
  distanceMiles   Float
  elapsedSeconds  Int
  paceSecPerMile  Float
  avgHeartRate    Int?
  elevationGainFt Float?
  elevationLossFt Float?
  startLat        Float?
  startLng        Float?

  @@index([workoutId, splitNumber])
  @@map("splits")
}

model TrackPoint {
  id        String  @id @default(cuid())
  workoutId String
  workout   Workout @relation(fields: [workoutId], references: [id], onDelete: Cascade)

  sequence   Int
  latitude   Float
  longitude  Float
  elevationM Float?
  timestamp  DateTime?
  elapsedSec Int?
  heartRate  Int?
  cadence    Int?
  speed      Float?

  @@index([workoutId, sequence])
  @@map("track_points")
}

model Quest {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  weekStart     DateTime // Monday 00:00:00 UTC
  difficulty    String   // "easy" | "medium" | "hard" | "epic"
  targetSeconds Int      // 3600 | 18000 | 36000 | 72000
  earnedSeconds Int      @default(0)

  status         String  @default("active") // "active" | "completed" | "failed"
  waypoint1Hit   Boolean @default(false)
  waypoint2Hit   Boolean @default(false)
  waypoint3Hit   Boolean @default(false)
  questCompleted Boolean @default(false)

  narrativeBeats Json    @default("[]") // [{waypointNum, text, triggeredAt}]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([userId, weekStart])
  @@index([userId, weekStart(sort: Desc)])
  @@map("quests")
}
